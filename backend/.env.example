# LLM Provider API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Default LLM Provider (openai | anthropic | minimax)
DEFAULT_LLM_PROVIDER=minimax
DEFAULT_MODEL_NAME=MiniMax-M2.7

# Database
DATABASE_URL=sqlite+aiosqlite:///./orchestrator.db

# Redis (optional, for distributed deployments)
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000
APP_API_KEY=your-secure-app-api-key-here

# Execution Settings
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT_SECONDS=300
